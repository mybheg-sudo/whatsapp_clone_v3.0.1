# MYBHEG Production Environment Configuration
# Copy this file to .env and update values for your production environment

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mybheg_db
DB_USER=mybheg_user
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# JWT Secret (minimum 32 characters)
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_LONG

# Application
APP_ENV=production
APP_URL=https://your-domain.com

# n8n Webhook
N8N_WEBHOOK_URL=https://n8n.motomotomasyon.com/webhook/send-whatsapp

# Security — These are enforced when APP_ENV=production
FORCE_HTTPS=true
CSP_ENABLED=true
