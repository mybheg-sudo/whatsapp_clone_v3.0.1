# MYBHEG WhatsApp Clone — Environment Variables Template
# Coolify'da bu değerleri Environment Variables bölümüne girin
APP_ENV=production

# Database — Coolify internal MySQL bağlantı bilgileri
DB_HOST=<COOLIFY_MYSQL_CONTAINER_NAME>
DB_PORT=3306
DB_NAME=default
DB_USER=mysql
DB_PASS=<MYSQL_PASSWORD>

# JWT Secret — production için güçlü bir anahtar oluşturun
JWT_SECRET=<STRONG_JWT_SECRET>

# n8n Webhook Base URL
N8N_BASE_URL=https://n8n.motomotomasyon.com

# Security
FORCE_HTTPS=false
CSP_ENABLED=true
